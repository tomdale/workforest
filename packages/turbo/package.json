{
  "name": "@wf-plugin/turbo",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./initializers/turbo-link": {
      "types": "./dist/initializers/turbo-link.d.mts",
      "import": "./dist/initializers/turbo-link.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsdown src/index.ts src/initializers/*.ts",
    "prepare": "tsdown src/index.ts src/initializers/*.ts",
    "prepack": "tsdown src/index.ts src/initializers/*.ts"
  },
  "dependencies": {
    "@wf-plugin/core": "workspace:*"
  },
  "workforest": {
    "plugin": {
      "initializers": [
        {
          "id": "turbo-link",
          "after": ["@wf-plugin/package-managers"],
          "requires": []
        }
      ]
    }
  }
}
