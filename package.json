{
  "name": "workforest",
  "version": "0.0.1",
  "description": "Initialize multiple repositories into a shared workspace",
  "author": "Tom Dale <tom.dale@vercel.com>",
  "keywords": [
    "cli",
    "workspace",
    "git",
    "worktree",
    "monorepo",
    "multi-repo",
    "developer-tools"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "workforest": "bin/workforest.js",
    "wf": "bin/workforest.js"
  },
  "scripts": {
    "build": "pnpm build:plugins && tsdown",
    "build:plugins": "pnpm --filter '@wf-plugin/*' build",
    "bench:ghostty": "tsx benchmarks/ghostty-real.ts",
    "bench:tui": "tsx benchmarks/tui-grid.ts",
    "check": "pnpm test && pnpm typecheck && pnpm lint",
    "lint": "biome check .",
    "prepack": "pnpm build:plugins && tsdown",
    "test": "pnpm build:plugins && vitest run",
    "typecheck": "pnpm build:plugins && tsc --noEmit"
  },
  "dependencies": {
    "@wf-plugin/core": "workspace:*",
    "@wf-plugin/package-managers": "workspace:*",
    "@wf-plugin/turbo": "workspace:*",
    "@wf-plugin/vercel": "workspace:*",
    "@unblessed/node": "1.0.0-alpha.23",
    "arg": "^5.0.2",
    "chalk": "^5.6.2",
    "jsonc-parser": "^3.3.1",
    "semver": "^7.7.3",
    "signal-exit": "^4.1.0",
    "slice-ansi": "^9.0.0",
    "string-width": "^8.2.1",
    "strip-ansi": "^7.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@types/node": "^24.10.4",
    "@types/semver": "^7.7.1",
    "tsdown": "^0.16.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  },
  "packageManager": "pnpm@10.22.0+sha512.bf049efe995b28f527fd2b41ae0474ce29186f7edcb3bf545087bd61fbbebb2bf75362d1307fda09c2d288e1e499787ac12d4fcb617a974718a6051f2eee741c",
  "engines": {
    "node": ">= 25"
  },
  "files": [
    "dist",
    "packages",
    "bin",
    "skills",
    "skill-data"
  ]
}
