{
  "name": "workforest",
  "version": "0.0.1",
  "description": "Initialize multiple repositories into a shared workspace",
  "author": "Tom Dale <tom.dale@vercel.com>",
  "keywords": [
    "cli",
    "workspace",
    "git",
    "worktree",
    "monorepo",
    "multi-repo",
    "developer-tools"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "workforest": "bin/workforest.js",
    "wf": "bin/workforest.js"
  },
  "scripts": {
    "build": "pnpm build:plugins && tsdown",
    "build:plugins": "pnpm --filter '@wf-plugin/*' build",
    "bench:ghostty": "tsx benchmarks/ghostty-real.ts",
    "bench:tui": "tsx benchmarks/tui-grid.ts",
    "check": "pnpm lint && pnpm knip && pnpm typecheck && pnpm test",
    "format": "biome format --write .",
    "integrate": "codex integrate",
    "knip": "knip",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepack": "pnpm build:plugins && tsdown",
    "test": "pnpm build && vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm build:plugins && tsc --noEmit",
    "wf": "WORKFOREST_USE_SOURCE_CLI=1 node bin/workforest.js"
  },
  "dependencies": {
    "@unblessed/node": "1.0.0-alpha.23",
    "@vercel/sandbox": "^2.2.1",
    "@wf-plugin/claude-cli": "workspace:*",
    "@wf-plugin/codex-cli": "workspace:*",
    "@wf-plugin/core": "workspace:*",
    "@wf-plugin/package-managers": "workspace:*",
    "@wf-plugin/turbo": "workspace:*",
    "@wf-plugin/vercel": "workspace:*",
    "@xterm/headless": "^6.0.0",
    "chalk": "^5.6.2",
    "jsonc-parser": "^3.3.1",
    "signal-exit": "^4.1.0",
    "slice-ansi": "^9.0.0",
    "string-width": "^8.2.1",
    "strip-ansi": "^7.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@types/node": "^24.10.4",
    "knip": "^6.23.0",
    "tsdown": "^0.16.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  },
  "files": [
    "dist",
    "bin",
    "skill-data"
  ],
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "warn"
    },
    "runtime": {
      "name": "node",
      "version": "25.9.0"
    }
  }
}
